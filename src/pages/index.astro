	<script>
		// Terminal-Typing im Hero — respektiert prefers-reduced-motion.
		const lines = [
			{ cmd: 'whoami', out: 'Alexander Ohl — IT-Generalist & KI-Engineer' },
			{ cmd: 'cat stack.txt', out: 'Web · SEO/GEO · KI-Automatisierung · E-Commerce' },
			{ cmd: './verfuegbarkeit.sh', out: '● verfügbar für Projekte — DACH · Remote' }
		];
		const el = document.getElementById('term-body');
		const PROMPT = 'alexander@ohl ~ % ';
		const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		function renderStatic() {
			if (!el) return;
			el.innerHTML = lines.map(l =>
				`<span class="p">${PROMPT}</span>${l.cmd}\n<span class="o">${l.out}</span>`
			).join('\n') + `\n<span class="p">${PROMPT}</span><span class="cursor"></span>`;
		}

		async function type() {
			if (!el) return;
			const sleep = (ms: number) => new Promise(r => setTimeout(r, ms));
			let html = '';
			for (const l of lines) {
				html += `<span class="p">${PROMPT}</span>`;
				for (const ch of l.cmd) {
					html += ch === '<' ? '&lt;' : ch;
					el.innerHTML = html + '<span class="cursor"></span>';
					await sleep(38 + Math.random() * 45);
				}
				await sleep(260);
				html += `\n<span class="o">${l.out}</span>\n`;
				el.innerHTML = html + '<span class="cursor"></span>';
				await sleep(420);
			}
			html += `<span class="p">${PROMPT}</span>`;
			el.innerHTML = html + '<span class="cursor"></span>';
		}

		if (reduced) { renderStatic(); } else { type(); }

		// WebMCP: Profil-Tool für KI-Browser registrieren (Progressive Enhancement)
		if (typeof navigator !== 'undefined' && 'modelContext' in navigator) {
			(navigator as any).modelContext.registerTool({
				name: 'getProfile',
				description: 'Liefert Profil, Kompetenzen und Kontaktdaten von Alexander Ohl (Freelance IT-Consultant).',
				parameters: { type: 'object', properties: {} },
				execute: async () => ({
					status: 'success',
					name: 'Alexander Ohl',
					role: 'Freelance IT-Consultant · KI-Automatisierungs-Engineer',
					skills: ['KI-Automatisierung (RAG, n8n, Agenten)', 'Webentwicklung (React, Next.js, Astro)', 'SEO & GEO', 'E-Commerce'],
					area: 'DACH · Remote',
					contact: 'info@pragma-code.de',
