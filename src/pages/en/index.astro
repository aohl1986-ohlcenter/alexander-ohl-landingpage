			font-size: 13px; font-weight: 700; color: var(--pc-green);
			padding: 8px 16px; border: 1px solid rgba(74, 222, 128, 0.25);
			border-radius: var(--pc-r-pill); background: rgba(74, 222, 128, 0.06);
		}
		.ft-social { display: flex; flex-wrap: wrap; gap: 8px; }
		.ft-social a {
