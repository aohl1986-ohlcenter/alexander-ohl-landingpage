};
---

<Layout
	title="Alexander Ohl | Freelance IT Consultant · AI & Web Development"
	description="Alexander Ohl — freelance IT consultant and founder of Pragma-Code: 15+ years of experience in AI automation, web development, SEO/GEO and e-commerce. Remote across the DACH region."
>
	<Fragment slot="head">
		<link rel="preload" as="image" href="/assets/alexander-ohl-buero-1200.webp" fetchpriority="high" />
		<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
	</Fragment>

	<!-- HEADER -->
	<header class="hd">
		<div class="pc-container hd-inner">
			<a class="hd-logo" href="/en" aria-label="Alexander Ohl — Home">
				<span class="prompt">alexander@ohl</span><span class="tilde">:~$</span><span class="caret" aria-hidden="true"></span>
			</a>
			<nav class="hd-nav" aria-label="Main navigation">
				<a href="#expertise">Expertise</a>
				<a href="#career">Career</a>
				<a href="#references">References</a>
				<a href="#contact" class="hd-cta">Contact</a>
				<a href="/" class="hd-lang" lang="de" aria-label="Zur deutschen Version wechseln">DE</a>
			</nav>
		</div>
	</header>

	<main>
		<!-- HERO -->
		<section class="hero">
			<div class="hero-bg" aria-hidden="true"></div>
			<div class="pc-container hero-inner">
				<div class="hero-copy">
					<div class="eyebrow pc-mono"><span class="bar"></span>Freelance IT Consultant · DACH · Remote</div>
					<h1>
						Alexander Ohl<br />
						<span class="yellow">— I build systems that work for you.</span>
					</h1>
					<p class="lede">
						Founder of <a href="https://www.pragma-code.de/" target="_blank" rel="noopener">Pragma-Code</a> with
						<strong>15+ years of experience</strong>: AI automation, modern web development,
						SEO &amp; GEO and e-commerce — from concept to measurable results.
					</p>
					<div class="hero-tags">
						<span class="tag"><span class="dot"></span>AI Automation</span>
						<span class="tag"><span class="dot"></span>Web Development</span>
						<span class="tag"><span class="dot"></span>SEO &amp; GEO</span>
						<span class="tag"><span class="dot"></span>E-Commerce</span>
					</div>
					<div class="hero-ctas">
						<a class="btn-primary" href="#contact">Start a project</a>
						<a class="btn-ghost" href="https://www.linkedin.com/in/alexander-ohl/" target="_blank" rel="noopener">LinkedIn ↗</a>
					</div>
				</div>

				<!-- Terminal card -->
				<div class="term" role="img" aria-label="Terminal: whoami — Alexander Ohl, IT generalist and AI engineer, available for projects">
					<div class="term-bar">
						<span class="tdot red"></span><span class="tdot ylw"></span><span class="tdot grn"></span>
						<span class="term-title pc-mono">alexander@ohl — zsh</span>
					</div>
					<pre class="term-body" id="term-body" aria-hidden="true"></pre>
				</div>
			</div>
		</section>

		<!-- PHOTO BANNER -->
		<section class="photo reveal">
			<div class="pc-container">
				<figure class="photo-frame">
					<img
						src="/assets/alexander-ohl-buero-1200.webp"
						srcset="/assets/alexander-ohl-buero-800.webp 800w, /assets/alexander-ohl-buero-1200.webp 1200w, /assets/alexander-ohl-buero-1600.webp 1600w"
						sizes="(max-width: 1200px) 100vw, 1104px"
						alt="Alexander Ohl at the Pragma Code office"
						width="1634" height="640"
						fetchpriority="high"
					/>
					<figcaption class="photo-strip">
						<span class="live"><span class="live-dot"></span>Available for projects</span>
						<span class="photo-meta">Alexander Ohl · Founder, Pragma-Code</span>
						<span class="photo-meta">DACH · Remote</span>
					</figcaption>
				</figure>
			</div>
		</section>

		<!-- STATS -->
		<section class="stats reveal" aria-label="Key figures">
			<div class="pc-container stats-inner">
				<div class="stat"><div class="num">15<span>+</span></div><div class="lab">Years of experience</div></div>
				<div class="stat"><div class="num">40<span>+</span></div><div class="lab">Projects delivered</div></div>
				<div class="stat"><div class="num">3</div><div class="lab">Languages, fluent</div></div>
				<div class="stat"><div class="num">&lt;24<span>h</span></div><div class="lab">Response time</div></div>
			</div>
		</section>

		<!-- TECH TICKER -->
		<div class="ticker" aria-hidden="true">
			<div class="ticker-track">
				{ticker.map(t => <span class="ticker-item">{t}</span>)}
			</div>
		</div>

		<!-- EXPERTISE -->
		<section class="sec" id="expertise">
			<div class="pc-container">
				<div class="sec-eyebrow pc-mono">01 — Expertise</div>
				<h2 class="sec-title">How I move businesses forward</h2>
				<div class="cards">
					<article class="card reveal">
						<div class="card-icon" aria-hidden="true">⚙︎</div>
						<h3>AI Automation</h3>
						<p>RAG pipelines, n8n workflows and autonomous AI agents that take over routine processes — safely integrated into existing systems.</p>
						<div class="card-chips"><span>RAG</span><span>n8n</span><span>Agents</span></div>
					</article>
					<article class="card reveal">
						<div class="card-icon" aria-hidden="true">&lt;/&gt;</div>
						<h3>Web Development</h3>
						<p>Fast, maintainable websites and applications with React, Next.js and Astro — performance and Core Web Vitals included.</p>
						<div class="card-chips"><span>React</span><span>Next.js</span><span>Astro</span></div>
					</article>
					<article class="card reveal">
						<div class="card-icon" aria-hidden="true">▲</div>
						<h3>SEO &amp; GEO</h3>
						<p>Technical SEO plus Generative Engine Optimization: structured data, llms.txt and content that AI search engines cite.</p>
						<div class="card-chips"><span>Schema.org</span><span>llms.txt</span><span>AI Search</span></div>
					</article>
					<article class="card reveal">
						<div class="card-icon" aria-hidden="true">◆</div>
						<h3>E-Commerce</h3>
						<p>Shops that sell: WooCommerce, Shopify and JTL — from product pages to conversion optimization.</p>
						<div class="card-chips"><span>WooCommerce</span><span>Shopify</span><span>JTL</span></div>
					</article>
				</div>
			</div>
		</section>

		<!-- CAREER -->
		<section class="sec sec-alt" id="career">
			<div class="pc-container">
				<div class="sec-eyebrow pc-mono">02 — Career</div>
				<h2 class="sec-title">From the engine room to AI</h2>
				<p class="sec-lede">From the frigate "Bayern" through system administration and agency work to independent IT generalist — every station sharpened the systems thinking that goes into every project today.</p>
				<ol class="tl">
					{timeline.map(item => (
						<li class="tl-item reveal">
							<div class="tl-year pc-mono">{item.year}</div>
							<div class="tl-body">
								<h3>{item.role}</h3>
								<div class="tl-org">{item.org}</div>
								<p>{item.text}</p>
							</div>
						</li>
					))}
				</ol>
				<div class="edu reveal">
					<div class="edu-label pc-mono">Education</div>
					<div class="edu-chips">
						{education.map(e => (
							<span class="edu-chip"><strong>{e.year}</strong> {e.title} · {e.org}</span>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- REFERENCES -->
		<section class="sec" id="references">
			<div class="pc-container">
				<div class="sec-eyebrow pc-mono">03 — References</div>
				<h2 class="sec-title">Selected projects</h2>
				<div class="refs">
					{references.map(r => (
						<a class="ref reveal" href={r.url} target="_blank" rel="noopener">
							<div class="ref-host pc-mono">{r.host} ↗</div>
							<h3>{r.name}</h3>
							<div class="ref-meta">{r.meta}</div>
							<p>{r.text}</p>
						</a>
					))}
				</div>
				<p class="refs-more">Detailed case studies with numbers and approach: <a href="https://www.pragma-code.de/en" target="_blank" rel="noopener">pragma-code.de</a></p>
			</div>
		</section>

		<!-- CONTACT -->
		<section class="sec sec-alt" id="contact">
			<div class="pc-container">
				<div class="contact reveal">
					<div class="sec-eyebrow pc-mono">04 — Contact</div>
					<h2 class="sec-title">Let's talk.</h2>
					<p class="sec-lede">A quick question, a concrete project or just an exploratory chat — I usually reply within 24 hours.</p>
					<div class="contact-actions">
						<a class="btn-primary" href="mailto:info@pragma-code.de">info@pragma-code.de</a>
						<a class="btn-ghost" href="https://www.pragma-code.de/en/request-a-quote" target="_blank" rel="noopener">Project request at Pragma-Code ↗</a>
						<a class="btn-ghost" href="https://www.linkedin.com/in/alexander-ohl/" target="_blank" rel="noopener">LinkedIn ↗</a>
					</div>
				</div>
			</div>
		</section>
	</main>

	<!-- FOOTER -->
	<footer class="ft">
		<div class="pc-container ft-social-row">
			<div class="ft-status"><span class="live-dot"></span>All systems functional</div>
			<nav class="ft-social" aria-label="Profiles">
				<a href="https://www.linkedin.com/in/alexander-ohl/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
				<a href="https://www.xing.com/profile/AlexanderOhl_PragmaCode" target="_blank" rel="noopener noreferrer">Xing</a>
				<a href="https://github.com/aohl1986-ohlcenter" target="_blank" rel="noopener noreferrer">GitHub</a>
				<a href="https://www.gulp.de/gulp2/g/spezialisten/resume/alexander.ohl" target="_blank" rel="noopener noreferrer">GULP</a>
				<a href="https://g.dev/alexanderohl" target="_blank" rel="noopener noreferrer">g.dev</a>
				<a href="https://www.provenexpert.com/pragma-code-llc/" target="_blank" rel="noopener noreferrer">ProvenExpert</a>
				<a href="https://www.behance.net/alexander-ohl" target="_blank" rel="noopener noreferrer">Behance</a>
			</nav>
		</div>
		<div class="pc-container ft-inner">
			<div class="ft-brand pc-mono">© {new Date().getFullYear()} Alexander Ohl · alexander-ohl.com</div>
			<nav class="ft-nav" aria-label="Legal">
				<a href="/impressum">Imprint</a>
				<a href="/datenschutz">Privacy</a>
				<a href="https://www.pragma-code.de/en/blog" target="_blank" rel="noopener">Blog ↗</a>
				<a href="https://www.pragma-code.de/en" target="_blank" rel="noopener">Pragma-Code ↗</a>
				<a href="/" lang="de">Deutsch</a>
			</nav>
		</div>
	</footer>

	<script>
		// Terminal typing in the hero — respects prefers-reduced-motion.
		const lines = [
			{ cmd: 'whoami', out: 'Alexander Ohl — IT generalist & AI engineer' },
			{ cmd: 'cat stack.txt', out: 'Web · SEO/GEO · AI automation · E-commerce' },
			{ cmd: './availability.sh', out: '● available for projects — DACH · Remote' }
		];
		const el = document.getElementById('term-body');
		const PROMPT = 'alexander@ohl ~ % ';
		const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		function renderStatic() {
			if (!el) return;
			el.innerHTML = lines.map(l =>
				`<span class="p">${PROMPT}</span>${l.cmd}\n<span class="o">${l.out}</span>`
			).join('\n') + `\n<span class="p">${PROMPT}</span><span class="cursor"></span>`;
		}

		async function type() {
			if (!el) return;
			const sleep = (ms: number) => new Promise(r => setTimeout(r, ms));
			let html = '';
			for (const l of lines) {
				html += `<span class="p">${PROMPT}</span>`;
				for (const ch of l.cmd) {
					html += ch === '<' ? '&lt;' : ch;
					el.innerHTML = html + '<span class="cursor"></span>';
					await sleep(38 + Math.random() * 45);
				}
				await sleep(260);
				html += `\n<span class="o">${l.out}</span>\n`;
				el.innerHTML = html + '<span class="cursor"></span>';
				await sleep(420);
			}
			html += `<span class="p">${PROMPT}</span>`;
			el.innerHTML = html + '<span class="cursor"></span>';
		}

		if (reduced) { renderStatic(); } else { type(); }

		// WebMCP: register a profile tool for AI browsers (progressive enhancement)
		if (typeof navigator !== 'undefined' && 'modelContext' in navigator) {
			(navigator as any).modelContext.registerTool({
				name: 'getProfile',
				description: 'Returns profile, skills and contact details of Alexander Ohl (freelance IT consultant).',
				parameters: { type: 'object', properties: {} },
				execute: async () => ({
					status: 'success',
					name: 'Alexander Ohl',
					role: 'Freelance IT Consultant · AI Automation Engineer',
					skills: ['AI automation (RAG, n8n, agents)', 'Web development (React, Next.js, Astro)', 'SEO & GEO', 'E-commerce'],
					area: 'DACH · Remote',
					contact: 'info@pragma-code.de',
					company: 'https://www.pragma-code.de'
				})
			});
		}
	</script>

	<style>
		/* ===== Header ===== */
		.hd {
			position: sticky; top: 0; z-index: 50;
			background: rgba(15, 20, 48, 0.82);
			backdrop-filter: blur(12px);
			-webkit-backdrop-filter: blur(12px);
			border-bottom: 1px solid var(--pc-line);
		}
		.hd-inner { display: flex; align-items: center; justify-content: space-between; height: 64px; }
		.hd-logo {
			font-family: var(--pc-font-mono); font-size: 15px; font-weight: 600;
			text-decoration: none; display: flex; align-items: center; gap: 1px;
		}
		.hd-logo .prompt { color: var(--pc-yellow); }
		.hd-logo .tilde { color: var(--pc-fg-2); }
		.hd-logo .caret {
			width: 8px; height: 16px; margin-left: 5px; background: var(--pc-green);
			animation: blink 1.2s steps(1) infinite;
		}
		@keyframes blink { 50% { opacity: 0; } }
		.hd-nav { display: flex; align-items: center; gap: clamp(14px, 2.5vw, 28px); }
		.hd-nav a {
			text-decoration: none; font-size: 14px; font-weight: 600; color: var(--pc-fg-2);
			transition: color var(--pc-fast) var(--pc-ease);
		}
		.hd-nav a:hover { color: var(--pc-fg); }
		.hd-cta {
			color: var(--pc-navy-900) !important; background: var(--pc-yellow);
			padding: 8px 16px; border-radius: var(--pc-r-pill);
		}
		.hd-cta:hover { background: var(--pc-yellow-soft); }
		.hd-lang {
			border: 1px solid var(--pc-line-2); padding: 6px 10px; border-radius: var(--pc-r-sm);
			font-family: var(--pc-font-mono); font-size: 12px !important;
		}
		/* Mobile: only CTA + language switch, hide anchor links */
		@media (max-width: 680px) {
			.hd-nav a:not(.hd-cta):not(.hd-lang) { display: none; }
			.hd-logo { font-size: 13.5px; }
		}

		/* ===== Hero ===== */
		.hero { position: relative; overflow: hidden; padding: clamp(56px, 9vw, 110px) 0; }
		.hero-bg {
			position: absolute; inset: 0; pointer-events: none;
			background:
				radial-gradient(ellipse 60% 50% at 75% 20%, rgba(255, 200, 41, 0.07), transparent 60%),
				radial-gradient(ellipse 50% 60% at 15% 85%, rgba(122, 167, 255, 0.06), transparent 60%),
				linear-gradient(var(--pc-line) 1px, transparent 1px),
				linear-gradient(90deg, var(--pc-line) 1px, transparent 1px);
			background-size: auto, auto, 56px 56px, 56px 56px;
			mask-image: radial-gradient(ellipse 90% 90% at 50% 40%, black 40%, transparent 100%);
		}
		.hero-inner {
			position: relative; display: grid; gap: clamp(32px, 5vw, 64px);
			grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr); align-items: center;
		}
		@media (max-width: 900px) { .hero-inner { grid-template-columns: 1fr; } }
		.eyebrow { display: flex; align-items: center; gap: 10px; color: var(--pc-yellow); margin-bottom: 20px; }
		.eyebrow .bar { width: 28px; height: 2px; background: var(--pc-yellow); }
		h1 {
			font-size: clamp(34px, 5.4vw, 60px); line-height: 1.08; font-weight: 800;
			letter-spacing: -0.02em; margin-bottom: 22px;
		}
		h1 .yellow { color: var(--pc-yellow); }
		.lede { font-size: clamp(16px, 1.6vw, 19px); color: var(--pc-fg-2); max-width: 56ch; margin-bottom: 26px; }
		.lede a { color: var(--pc-yellow); text-decoration: none; border-bottom: 1px solid rgba(255,200,41,.35); }
		.hero-tags { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 30px; }
		.tag {
			display: inline-flex; align-items: center; gap: 8px; padding: 7px 14px;
			border: 1px solid var(--pc-line-2); border-radius: var(--pc-r-pill);
			font-size: 13px; font-weight: 600; color: var(--pc-fg-2); background: rgba(255,255,255,0.02);
		}
		.tag .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--pc-yellow); }
		.hero-ctas { display: flex; flex-wrap: wrap; gap: 14px; }
		.btn-primary {
			background: var(--pc-yellow); color: var(--pc-navy-900); text-decoration: none;
			font-weight: 800; padding: 14px 26px; border-radius: var(--pc-r-md);
			box-shadow: var(--pc-shadow-yellow);
			transition: transform var(--pc-fast) var(--pc-ease), box-shadow var(--pc-fast) var(--pc-ease), background var(--pc-fast) var(--pc-ease);
		}
		.btn-primary:hover { background: var(--pc-yellow-soft); transform: translateY(-2px); box-shadow: var(--pc-shadow-yellow-hover); }
		.btn-ghost {
			border: 1px solid var(--pc-line-2); color: var(--pc-fg); text-decoration: none;
			font-weight: 700; padding: 14px 22px; border-radius: var(--pc-r-md);
			transition: border-color var(--pc-fast) var(--pc-ease), background var(--pc-fast) var(--pc-ease);
		}
		.btn-ghost:hover { border-color: var(--pc-yellow); background: rgba(255, 200, 41, 0.06); }

		/* Terminal */
		.term {
