const ticker = [...stack, ...stack];

const timeline: { year: string; role: string; org: string; text: string }[] = [
	{ year: '2024', role: 'Founder & IT Generalist', org: 'Pragma-Code', text: 'IT consulting for SMEs: AI automation (RAG, n8n), full-stack web development, SEO and e-commerce.' },
	{ year: '2023', role: 'PPC Manager / User Acquisition', org: 'Next Choice Agency', text: 'Paid media and data-driven funnel optimization. Through Studio 360°, supported agency clients — including Alando in Osnabrück (hotel, bar & event venue).' },
	{ year: '2020', role: 'Founder, Digital Agency', org: 'Studio 360°', text: 'International digital agency for web development and online marketing.' },
	{ year: '2018', role: 'IT Freelancer', org: 'Self-employed · Remote', text: 'Remote projects in IT, web, SEO and online marketing for clients in Germany — up to seven in parallel.' },
	{ year: '2016', role: 'Founder & Managing Director', org: 'OHLcenter EDV', text: 'Own web and IT agency: web design, online marketing, SEO, Google & Meta Ads, CRM integration, sales automation.' },
	{ year: '2013', role: 'Marketing Manager', org: 'Netrise Solution GmbH & Co. KG', text: 'Built up sales, import/export of Cisco, HP and Juniper systems.' },
	{ year: '2012', role: 'System Administrator', org: 'Jewish Community of Osnabrück', text: 'Responsible for the entire IT infrastructure: IT training room with 20 PCs, fiber-optic connection, member database, NAS server, campus-wide networking.' },
	{ year: '2010', role: 'Electronics Technician, Automation', org: 'EST GmbH', text: 'Assembly and commissioning of automation and control technology.' },
	{ year: '2009', role: 'IT System Administrator', org: 'KiKxxl GmbH', text: 'Maintenance and support of IT systems in live operation — first professional role.' },
	{ year: '2005', role: 'Navy Serviceman (4-year term)', org: 'German Navy · Wilhelmshaven', text: 'Service aboard the frigate "Bayern" (F217).' },
];

const education: { year: string; title: string; org: string }[] = [
	{ year: '2013', title: 'Mechatronics studies', org: 'Osnabrück University of Applied Sciences' },
	{ year: '2009', title: 'Abitur (evening school)', org: 'Sophie Scholl Evening Grammar School' },
	{ year: '2004', title: 'Vocational college, IT', org: 'BBS Bersenbrück' },
	{ year: '2004', title: 'Secondary school certificate', org: 'Realschule Neuenkirchen' },
];

const references: { url: string; host: string; name: string; meta: string; text: string }[] = [
	{ url: 'https://www.imkerpur.de/', host: 'imkerpur.de', name: 'ImkerPur', meta: 'Online shop · Honey & beekeeping', text: 'Extended the JTL shop with SEO-optimized product and landing pages, grew organic search visibility.' },
	{ url: 'https://k-kbau.de/', host: 'k-kbau.de', name: 'K&K Bau GbR', meta: 'Construction company', text: 'Designed and built the complete web presence, then optimized it for search engines.' },
	{ url: 'https://www.alando-palais.de/', host: 'alando-palais.de', name: 'Alando Palais', meta: 'Hotel · Bar · Event venue · Osnabrück', text: 'Upgraded the online presence together with the Next Choice agency — Google Business Profile and reputation management.' },
	{ url: 'https://www.kasinopark.com/', host: 'kasinopark.com', name: 'Kasinopark', meta: 'Event house · Georgsmarienhütte', text: 'Multi-year engagement: web development, online presence, online marketing and SEO.' },
	{ url: 'https://shooting-solutions.de/', host: 'shooting-solutions.de', name: 'Shooting Solutions', meta: 'Shooting sports & training', text: 'Six-month SEO sprint: link building, technical SEO, local SEO and editorial blog articles.' },
	{ url: 'https://yms-osnabrueck.de/', host: 'yms-osnabrueck.de', name: 'YMS Osnabrück', meta: 'Osnabrück', text: 'Supported for over a year: SEO, visibility, Google Business Profile and social media.' },
