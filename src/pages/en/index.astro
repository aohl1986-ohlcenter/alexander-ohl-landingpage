		.ft-inner { display: flex; flex-wrap: wrap; gap: 14px 28px; align-items: center; justify-content: space-between; }
		.ft-brand { color: var(--pc-fg-2); }
		.ft-nav { display: flex; flex-wrap: wrap; gap: 20px; }
