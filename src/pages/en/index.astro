		.photo-strip {
			display: flex; flex-wrap: wrap; align-items: center; gap: 10px 26px;
			padding: 14px 22px; background: var(--pc-navy-900); border-top: 1px solid var(--pc-line);
			font-size: 13px; color: var(--pc-fg-2);
