			display: inline-block; width: 8px; height: 15px; vertical-align: -2px;
			background: var(--pc-green); animation: blink 1.1s steps(1) infinite;
		}

		/* ===== Photo banner ===== */
		.photo { padding: clamp(10px, 2vw, 24px) 0 0; }
		.photo-frame {
			border: 1px solid var(--pc-line-2); border-radius: var(--pc-r-xl);
			overflow: hidden; box-shadow: var(--pc-shadow-card);
		}
