		.contact-actions { display: flex; flex-wrap: wrap; gap: 14px; justify-content: center; }

		/* Footer */
		.ft { border-top: 1px solid var(--pc-line); padding: 24px 0 28px; background: var(--pc-navy-900); }
		.ft-social-row {
			display: flex; flex-wrap: wrap; gap: 14px 28px; align-items: center;
			justify-content: space-between; padding-bottom: 20px; margin-bottom: 20px;
