const personSchema = {
	"@context": "https://schema.org",
	"@type": "ProfilePage",
	"name": "Alexander Ohl — Freelance IT Consultant & AI Automation Engineer",
	"url": "https://www.alexander-ohl.com/en",
	"inLanguage": "en",
	"mainEntity": {
		"@type": "Person",
		"@id": "https://www.alexander-ohl.com/#person",
		"name": "Alexander Ohl",
		"jobTitle": "AI Automation Engineer & IT Generalist",
		"url": "https://www.alexander-ohl.com/en",
		"image": "https://www.alexander-ohl.com/assets/alexander-ohl-portrait.webp",
		"email": "mailto:info@pragma-code.de",
		"sameAs": [
			"https://www.linkedin.com/in/alexander-ohl/",
			"https://github.com/aohl1986-ohlcenter",
			"https://www.pragma-code.de/alexander-ohl"
		],
		"worksFor": {
			"@type": "Organization",
			"name": "Pragma-Code",
			"url": "https://www.pragma-code.de"
		},
		"knowsAbout": ["AI automation", "Web development", "SEO", "Generative Engine Optimization", "E-commerce", "React", "Next.js", "Astro", "n8n", "RAG"],
		"knowsLanguage": ["de", "en", "ru"],
		"alumniOf": [
			{ "@type": "EducationalOrganization", "name": "Osnabrück University of Applied Sciences" },
			{ "@type": "EducationalOrganization", "name": "Sophie Scholl Evening Grammar School" }
