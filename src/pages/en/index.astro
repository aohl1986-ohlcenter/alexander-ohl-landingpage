			font-family: var(--pc-font-mono); font-size: 11px; padding: 4px 10px;
			border: 1px solid var(--pc-line-2); border-radius: var(--pc-r-pill); color: var(--pc-fg-3);
		}

		/* Timeline */
		.tl { list-style: none; padding: 0; position: relative; max-width: 760px; }
		.tl::before {
			content: ''; position: absolute; left: 74px; top: 8px; bottom: 8px; width: 2px;
			background: linear-gradient(to bottom, var(--pc-yellow), rgba(255, 200, 41, 0.08));
		}
		.tl-item { display: grid; grid-template-columns: 56px 1fr; gap: 36px; padding: 0 0 34px; position: relative; }
		.tl-item::before {
			content: ''; position: absolute; left: 69px; top: 7px; width: 12px; height: 12px;
			border-radius: 50%; background: var(--pc-navy-800); border: 2px solid var(--pc-yellow);
		}
		.tl-year { color: var(--pc-yellow); font-size: 13px !important; padding-top: 5px; text-align: right; }
