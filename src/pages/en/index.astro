		.term-title { margin-left: 8px; color: var(--pc-fg-3); }
		.term-body {
			padding: 20px; margin: 0; font-family: var(--pc-font-mono); font-size: 13.5px;
			line-height: 1.85; white-space: pre-wrap; word-break: break-word;
			min-height: 216px; color: var(--pc-fg);
		}
		.term-body :global(.p) { color: var(--pc-yellow); }
